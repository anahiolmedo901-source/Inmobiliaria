# ── Base de datos (Supabase = PostgreSQL) ────────────────
DB_CLIENT=pg              # mysql2 | pg
DB_HOST=db.tu-proyecto.supabase.co
DB_PORT=5432              # 3306 MySQL | 5432 PostgreSQL
DB_USER=postgres
DB_PASSWORD=tu_contraseña_de_supabase
DB_NAME=postgres
DB_SSL=true               # true = obligatorio en Supabase

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=genera_un_secreto_aleatorio_aqui
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081

# ── HTTPS / SSL (optativo) ─────────────────────────────────
# HTTPS_PORT=4100
# SSL_KEY_PATH=./ssl/viviana-dev.key
# SSL_CERT_PATH=./ssl/viviana-dev.crt
# Ejecuta: npm run gencerts  (genera certs auto-firmados en ./ssl/)

# ── Seed (opcional — valores por defecto para desarrollo) ──
# SEED_PASSWORD_ADMIN=Admin123!
# SEED_PASSWORD_AGENT=Agent123!
# SEED_PASSWORD_CLIENT=Client123!
