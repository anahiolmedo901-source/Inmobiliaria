{
  "name": "viviana",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "echo \"Error: no test framework configured\" && exit 1",
    "dev:backend": "tsx watch src/index.ts",
    "build:backend": "tsc",
    "start:backend": "node dist/index.js",
    "start:https": "tsx src/index.ts",
    "gencerts": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-certs.ps1",
    "migrate": "tsx src/migrate.ts",
    "migrate:down": "tsx src/migrate.ts rollback",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "@expo/vector-icons": "^15.1.1",
    "expo": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "^1.27.2",
    "react-native-web": "^0.21.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.11.0",
    "mysql2": "^3.12.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2"
  }
}
